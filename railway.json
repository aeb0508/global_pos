{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "apache2-foreground",
        "healthcheckPath": "/backend/api/",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "frontend": {
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "serve -s build/web -l $PORT",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      }
    }
  }
}</content>
