# Frontend Environment Configuration
# This file is for reference only - actual configuration is in lib/utils/api_config.dart

# Production Server (Default)
# Used when app is deployed or accessed from non-localhost domains
PRODUCTION_API_URL=https://posys.ct.ws/backend/api

# Development Server (Localhost)
# Used only when running on http://localhost or http://127.0.0.1
LOCALHOST_API_URL=http://localhost/backend/api

# Custom Server (Optional)
# Can be set via app settings at runtime
# CUSTOM_API_URL=https://your-custom-server.com/backend/api

# Notes:
# - No need to set environment variables - configuration is automatic
# - App detects localhost vs production automatically
# - Custom URL can be set in app settings
# - See API_CONFIGURATION.md for details
