# Global POS Backend Configuration
# IMPORTANT: Copy this file to .env and update with your actual settings
# DO NOT commit .env file to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_NAME=global_pos
DB_USER=root
DB_PASSWORD=

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# SECURITY WARNING: Generate a new random secret key for production!
# Use: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_EXPIRATION=86400

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_NAME=Global POS

# ============================================================================
# COMPANY BRANDING
# ============================================================================
COMPANY_NAME=Global POS
COMPANY_TAGLINE=Point of Sale System
COMPANY_EMAIL=noreply@globalpos.com

# ============================================================================
# CORS SETTINGS
# ============================================================================
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ============================================================================
# FILE UPLOAD SETTINGS
# ============================================================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp
UPLOAD_DIR=uploads/products/

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=noreply@globalpos.com
SMTP_FROM_NAME=Global POS
SMTP_TIMEOUT=15

# ============================================================================
# PAGINATION
# ============================================================================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100
DEFAULT_ORDER_LIMIT=100

# ============================================================================
# SECURITY
# ============================================================================
PASSWORD_MIN_LENGTH=6
SESSION_LIFETIME=1440
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900

# ============================================================================
# ORDER SETTINGS
# ============================================================================
ORDER_NUMBER_PREFIX=ORD
TRANSFER_NUMBER_PREFIX=TRF
